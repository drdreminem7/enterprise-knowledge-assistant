# Application
PROJECT_NAME=Enterprise Knowledge Assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# PostgreSQL
# For local runs outside Docker, localhost is correct.
# In Docker Compose, the backend overrides DATABASE_URL and POSTGRES_HOST to use the db service.
POSTGRES_DB=enterprise_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/enterprise_assistant

# Document ingestion
UPLOAD_DIR=backend/uploads
MAX_UPLOAD_SIZE_MB=25

# LLM and embeddings
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-3-flash-preview,gemini-2.5-flash-lite,gemma-3-27b-it,gemma-3-12b-it,gemma-3-4b-it,gemma-3-1b-it
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

# Frontend
# This is read at frontend build time.
VITE_API_BASE_URL=http://localhost:8000/api
